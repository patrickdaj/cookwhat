    {
      "title": "My Mother's Meatballs",
      "page": 156,
      "chapter": "Secondi",
      "note": "signature family meatballs (Le Polpette della Mamma)",
      "protein": "beef",
      "scanned": true,
      "makes": "8 large meatballs",
      "captured": {
        "ingredients": [
          "1 ciabatta roll, cut into small cubes",
          "about 1 cup (240 ml) milk",
          "1 lb (455 g) ground beef",
          "1/2 cup (50 g) freshly grated Grana Padano",
          "1/2 cup (30 g) minced white onion",
          "4 tsp minced garlic",
          "2 tbsp white wine",
          "1 large egg",
          "2 large egg yolks",
          "1/3 cup (13 g) finely chopped fresh parsley",
          "1 1/2 tsp freshly grated lemon zest",
          "2 tsp salt",
          "1 tsp freshly ground black pepper",
          "1/4 cup (60 ml) extra-virgin olive oil",
          "3-4 sprigs fresh rosemary"
        ],
        "steps": [
          "Soak the cubed ciabatta in milk ~30 min until completely soggy.",
          "Mix the beef with the Grana Padano, onion, garlic, wine, egg, egg yolks, parsley, lemon zest, salt, and pepper.",
          "Squeeze the milk from the bread and mix it into the meat.",
          "Form 8 large (~4 oz) meatballs - roll round, then press to flatten slightly.",
          "Sear in very hot oil with the rosemary, 3 min undisturbed for a crust, then flip and cook 3 min, basting.",
          "Reduce heat to low, cover, and cook 8-10 min more until done, basting frequently. Serve family-style."
        ],
        "tips": [
          "The milk-soaked bread (panade) keeps the meatballs tender - let it get fully soggy.",
          "Don't move them for the first 3 minutes or they'll fall apart; let the crust set first.",
          "Baste frequently with the rendered juices and finish covered on low so they cook through without drying."
        ],
        "serveWith": "salad, roasted potatoes (p.171), grilled vegetables (p.174), or polenta (p.172)"
      }
    },
